# Copy to backend/.env and fill in your values. Never commit .env.

# --- Supabase Session pooler (recommended) ---
# Project Settings → Database → Connection string → Session pooler → URI
# Add jdbc: prefix and ?sslmode=require:
# DATABASE_URL=jdbc:postgresql://aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
# DATABASE_USERNAME=postgres.YOUR_PROJECT_REF
# DATABASE_PASSWORD=your_database_password

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Auth — use a long random string (at least 32 characters)
JWT_SECRET=shopops-local-dev-jwt-secret-change-me-32chars

# Load demo products/orders on first startup (set false in production)
SEED_ENABLED=true

# --- Shopify (Dev Dashboard app) ---
# dev.shopify.com → Apps → your app → Settings → copy Client ID + Client secret
# Install the app on your dev store first (Home → Install app)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_CLIENT_ID=your-client-id
SHOPIFY_CLIENT_SECRET=your-client-secret
SHOPIFY_API_VERSION=2025-01
# Optional legacy: static token instead of client id/secret
# SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
