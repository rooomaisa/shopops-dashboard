# Copy to backend/.env and fill in your values. Never commit .env.

# --- Supabase Session pooler (recommended) ---
# Project Settings → Database → Connection string → Session pooler → URI
# Add jdbc: prefix and ?sslmode=require:
# DATABASE_URL=jdbc:postgresql://aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
# DATABASE_USERNAME=postgres.YOUR_PROJECT_REF
# DATABASE_PASSWORD=your_database_password

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Load demo products/orders on first startup (set false in production)
SEED_ENABLED=true
